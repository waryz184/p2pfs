# =============================================================================
# Caddyfile — terminaison TLS (Let's Encrypt auto) devant p2pfs.
# p2pfs n'écoute QUE sur 127.0.0.1:8000 ; Caddy est la seule porte publique.
#
# Déploiement : remplacer vault.example.com par votre domaine (A/AAAA -> VPS).
# Caddy obtient et renouvelle le certificat tout seul. Aucun cron, aucun certbot.
# =============================================================================

vault.example.com {
	encode zstd gzip

	# p2pfs pose déjà CSP/HSTS, mais on renforce ici au cas où.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}

	# Limite la taille des corps de requête (défense en profondeur ; p2pfs
	# limite déjà les blobs à 64 MiB côté applicatif).
	request_body {
		max_size 80MB
	}

	# Caddy POSE X-Forwarded-For = IP réelle du client (remplace tout en-tête
	# entrant). p2pfs ne croit cet en-tête que s'il vient d'un -trusted-proxies
	# (loopback par défaut, ce qui correspond à ce reverse_proxy 127.0.0.1) ; un
	# attaquant frappant p2pfs en direct ne peut donc pas usurper son IP (F2).
	reverse_proxy 127.0.0.1:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
	}

	log {
		output file /var/log/caddy/vault.log
		format json
	}
}

# Rate-limiting natif : nécessite le module caddy-ratelimit (build xcaddy).
# Sinon, le rate-limit applicatif de p2pfs (par IP, sur /challenge + /login)
# suffit pour un POC. Pour l'activer :
#   xcaddy build --with github.com/mholt/caddy-ratelimit
# puis décommenter un bloc `rate_limit` ici.
